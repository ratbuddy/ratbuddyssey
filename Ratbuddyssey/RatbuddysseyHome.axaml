<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scott="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        mc:Ignorable="d"
        x:Class="Ratbuddyssey.RatbuddysseyHome"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        DragDrop.AllowDrop="True">

  <Grid DataContext="{Binding AudysseyMultEQApp}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Menu -->
    <Menu Grid.Row="0">
      <MenuItem Header="_File">
        <MenuItem Header="_Open Audyssey file" Command="{Binding $parent[Window].DataContext.OpenFileCommand}"/>
        <MenuItem Header="Open _Recent" x:Name="RecentFilesMenu"/>
        <MenuItem Header="_Reload (discard unsaved changes)" Command="{Binding $parent[Window].DataContext.ReloadFileCommand}"/>
        <Separator/>
        <MenuItem Header="_Save" Command="{Binding $parent[Window].DataContext.SaveFileCommand}"/>
        <MenuItem Header="Save _As" Command="{Binding $parent[Window].DataContext.SaveFileAsCommand}"/>
        <Separator/>
        <MenuItem Header="E_xit" Command="{Binding $parent[Window].DataContext.ExitProgramCommand}"/>
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="_Light theme" Click="OnLightThemeClicked"/>
        <MenuItem Header="_Dark theme" Click="OnDarkThemeClicked"/>
        <MenuItem Header="Use _system theme" Click="OnSystemThemeClicked"/>
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="Apply AudysseyOne _post-process…"
                  ToolTip.Tip="Destructive: replaces measurement responses with neutral impulses and resets several flags. See README."
                  Click="OnApplyAudysseyOnePostProcessClicked"/>
      </MenuItem>
      <MenuItem Header="_About">
        <MenuItem Header="About Ratbuddyssey" Command="{Binding $parent[Window].DataContext.AboutCommand}"/>
      </MenuItem>
    </Menu>

    <!-- Tab content -->
    <TabControl x:Name="tabControl" Grid.Row="2">
      <TabItem x:Name="TabFile" Header="App">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="260"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="320"/>
          </Grid.ColumnDefinitions>
          <Grid Grid.Column="0">
            <Grid.RowDefinitions>
              <RowDefinition Height="*" MinHeight="160"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*" MinHeight="160"/>
            </Grid.RowDefinitions>
            <HeaderedContentControl Header="Channels">
              <DockPanel>
                <TextBox DockPanel.Dock="Top" Margin="2,2,2,4"
                         Watermark="Filter by speaker or commandId"
                         Text="{Binding $parent[Window].DataContext.ChannelFilter, Mode=TwoWay}"/>
                <DataGrid x:Name="channelsView"
                          ItemsSource="{Binding $parent[Window].DataContext.FilteredChannelRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          SelectionChanged="ChannelsView_SelectionChanged">
                  <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="28" CanUserResize="False" CanUserSort="False" IsReadOnly="True">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Ellipse Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   ToolTip.Tip="{Binding Validation.Message}">
                            <Ellipse.Fill>
                              <MultiBinding Converter="{StaticResource StatusKindToBrush}">
                                <Binding Path="StatusKind"/>
                              </MultiBinding>
                            </Ellipse.Fill>
                          </Ellipse>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Speaker" Binding="{Binding SpeakerName}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="commandId" Binding="{Binding Channel.CommandId}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Channel.EnChannelType}" IsReadOnly="True" Width="60"/>
                    <DataGridTextColumn Header="X-over" Binding="{Binding Channel.CustomCrossover}" IsReadOnly="True" Width="70"/>
                    <DataGridCheckBoxColumn Header="Sticky" Binding="{Binding Channel.Sticky}"/>
                  </DataGrid.Columns>
                </DataGrid>
              </DockPanel>
            </HeaderedContentControl>
            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Height="5" ResizeDirection="Rows"/>
            <HeaderedContentControl Grid.Row="2" Header="House Curve Presets">
              <StackPanel>
                <ComboBox x:Name="houseCurveCombo"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{Binding $parent[Window].DataContext.HouseCurves}"
                          SelectedItem="{Binding $parent[Window].DataContext.SelectedHouseCurve, Mode=TwoWay}"
                          DisplayMemberBinding="{Binding Name}"
                          ToolTip.Tip="{Binding $parent[Window].DataContext.SelectedHouseCurve.Description}"/>
                <TextBlock Text="{Binding $parent[Window].DataContext.SelectedHouseCurve.Description}"
                           TextWrapping="Wrap"
                           Opacity="0.75"
                           FontSize="11"
                           Margin="0,6,0,0"/>
                <WrapPanel Margin="0,8,0,0">
                  <Button Content="Apply to selected"
                          Click="OnApplyHouseCurveToSelectedClicked"
                          Margin="0,0,6,6"/>
                  <Button Content="Apply to all channels"
                          Click="OnApplyHouseCurveToAllClicked"
                          ToolTip.Tip="Applies the curve to every channel. Subwoofers receive only the bass-shelf portion of the curve (trimmed at 200 Hz) since they don't reproduce the treble."
                          Margin="0,0,0,6"/>
                </WrapPanel>
              </StackPanel>
            </HeaderedContentControl>
            <HeaderedContentControl Grid.Row="3" Header="Target Curve Points"
                                    DataContext="{Binding #channelsView.SelectedItem.Channel}">
              <DockPanel>
                <StackPanel DockPanel.Dock="Bottom">
                  <WrapPanel Margin="6">
                    <TextBox x:Name="keyTbx" Width="60" Watermark="Hz" Margin="0,0,6,4"/>
                    <TextBox x:Name="valueTbx" Width="60" Watermark="dB" Margin="0,0,6,4"/>
                    <Button Content="Add" Click="ButtonClickAddTargetCurvePoint" Margin="0,0,0,4"/>
                  </WrapPanel>
                </StackPanel>
                <DataGrid x:Name="dataGrid" ItemsSource="{Binding CustomTargetCurvePointsDictionary}"
                          AutoGenerateColumns="False" CanUserSortColumns="False">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Frequency" Binding="{Binding Key}" Width="*" MinWidth="70"/>
                    <DataGridTextColumn Header="dB" Binding="{Binding Value}" Width="*" MinWidth="60"/>
                    <DataGridTemplateColumn Width="Auto">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Button Content="Delete" Click="ButtonClickRemoveTargetCurvePoint"/>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                  </DataGrid.Columns>
                </DataGrid>
              </DockPanel>
            </HeaderedContentControl>
          </Grid>
          <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"/>
          <Grid Grid.Column="2">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <HeaderedContentControl Header="Status">
              <StackPanel>
                <!-- Top row: file path is always full-width, never side-by-side. -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="Current File:" Margin="4" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding $parent[Window].DataContext.CurrentFilePath}"
                             TextTrimming="CharacterEllipsis"
                             ToolTip.Tip="{Binding $parent[Window].DataContext.CurrentFilePath}"
                             Margin="4" VerticalAlignment="Center"/>
                </Grid>
                <Grid Margin="0,4,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="Amp Assign Info" Margin="4" VerticalAlignment="Center"/>
                  <TextBox   Grid.Column="1" Text="{Binding AmpAssignInfo}" Margin="2" VerticalAlignment="Center"
                             FontFamily="Consolas,Menlo,monospace"/>
                </Grid>
                <!-- Field cards reflow as the column gets narrower. -->
                <WrapPanel Margin="0,4,0,0">
                  <WrapPanel.Resources>
                    <!-- Each card is a label-above-value pair with a fixed minimum width
                         so we always see the whole label + a usable input. -->
                  </WrapPanel.Resources>
                  <StackPanel Width="200" Margin="0,0,8,6">
                    <TextBlock Text="Title" Margin="2,0" Opacity="0.75" FontSize="11"/>
                    <TextBox Text="{Binding Title}" Margin="2"/>
                  </StackPanel>
                  <StackPanel Width="200" Margin="0,0,8,6">
                    <TextBlock Text="Target Model Name" Margin="2,0" Opacity="0.75" FontSize="11"/>
                    <TextBox Text="{Binding TargetModelName}" Margin="2"/>
                  </StackPanel>
                  <StackPanel Width="160" Margin="0,0,8,6">
                    <TextBlock Text="Interface Version" Margin="2,0" Opacity="0.75" FontSize="11"/>
                    <TextBox Text="{Binding InterfaceVersion}" Margin="2"/>
                  </StackPanel>
                  <StackPanel Width="160" Margin="0,0,8,6">
                    <TextBlock Text="Upgrade Info" Margin="2,0" Opacity="0.75" FontSize="11"/>
                    <TextBox Text="{Binding UpgradeInfo}" Margin="2"/>
                  </StackPanel>
                  <StackPanel Width="160" Margin="0,0,8,6">
                    <TextBlock Text="ADC Lineup" Margin="2,0" Opacity="0.75" FontSize="11"/>
                    <TextBox Text="{Binding AdcLineup}" Margin="2"/>
                  </StackPanel>
                  <StackPanel Width="160" Margin="0,0,8,6">
                    <TextBlock Text="System Delay" Margin="2,0" Opacity="0.75" FontSize="11"/>
                    <TextBox Text="{Binding SystemDelay}" Margin="2"/>
                  </StackPanel>
                  <StackPanel Width="200" Margin="0,0,8,6">
                    <TextBlock Text="Amp Assign Type" Margin="2,0" Opacity="0.75" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding AmpAssignTypeList}" SelectedIndex="{Binding EnAmpAssignType}"
                              HorizontalAlignment="Stretch" Margin="2"/>
                  </StackPanel>
                  <StackPanel Width="200" Margin="0,0,8,6">
                    <TextBlock Text="MultEQ Type" Margin="2,0" Opacity="0.75" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding MultEQTypeList}" SelectedIndex="{Binding EnMultEQType}"
                              HorizontalAlignment="Stretch" Margin="2"/>
                  </StackPanel>
                  <StackPanel Width="200" Margin="0,0,8,6">
                    <TextBlock Text="Target Curve Type" Margin="2,0" Opacity="0.75" FontSize="11"/>
                    <ComboBox x:Name="TargetCurveType" SelectedIndex="{Binding EnTargetCurveType}"
                              ItemsSource="{Binding TargetCurveTypeList}"
                              HorizontalAlignment="Stretch" Margin="2"
                              SelectionChanged="TargetCurveTypeSelectionChanged"/>
                  </StackPanel>
                  <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="1" CornerRadius="4" Padding="6,4" Margin="0,0,8,6">
                    <WrapPanel>
                      <CheckBox Content="Dynamic EQ" IsChecked="{Binding DynamicEq}" Margin="0,0,8,2"/>
                      <CheckBox Content="Dynamic Volume" IsChecked="{Binding DynamicVolume}" Margin="0,0,8,2"/>
                      <CheckBox Content="LFC" IsChecked="{Binding Lfc}" Margin="0,0,8,2"/>
                      <CheckBox Content="Auro" IsChecked="{Binding Auro}" IsEnabled="False"
                                ToolTip.Tip="Reported by the receiver; not user-editable."
                                Margin="0,0,8,2"/>
                      <CheckBox Content="LFC Support" IsChecked="{Binding LfcSupport}" IsEnabled="False"
                                ToolTip.Tip="Reported by the receiver; not user-editable."
                                Margin="0,0,8,2"/>
                    </WrapPanel>
                  </Border>
                </WrapPanel>
              </StackPanel>
            </HeaderedContentControl>
            <GridSplitter Grid.Row="1" Height="5" ResizeDirection="Rows" HorizontalAlignment="Stretch"/>
            <Grid Grid.Row="2">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="240"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Grid Grid.Column="0" DataContext="{Binding #channelsView.SelectedItem.Channel}">
                <TabControl>
                  <TabItem Header="Levels">
                    <ScrollViewer>
                      <Grid Margin="6">
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="160" MinWidth="120"/>
                          <ColumnDefinition Width="*" MinWidth="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Trim adjustment (dB)" Margin="4" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding TrimAdjustment}" Margin="2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Custom level (dB)" Margin="4" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding CustomLevel}" Margin="2"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Delay adjustment (s)" Margin="4" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding DelayAdjustment}" Margin="2"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Custom distance (m)" Margin="4" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding CustomDistance}" Margin="2"/>
                        <CheckBox  Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                   Content="Skipped measurement" IsChecked="{Binding IsSkipMeasurement}" Margin="4"/>
                        <CheckBox  Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                   Content="Midrange compensation" IsChecked="{Binding MidrangeCompensation}"
                                   IsCheckedChanged="OnTargetProjectionInputChanged"
                                   ToolTip.Tip="Audyssey's gentle ~2 dB dip around 2 kHz to counter the perceived brightness of flat-measured loudspeakers in real rooms. The dashed 'projected' line on the chart shows the effective target with this dip baked in."
                                   Margin="4"/>
                      </Grid>
                    </ScrollViewer>
                  </TabItem>
                  <TabItem Header="Crossover">
                    <ScrollViewer>
                      <Grid Margin="6">
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="160" MinWidth="120"/>
                          <ColumnDefinition Width="*" MinWidth="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Custom crossover (Hz)" Margin="4" VerticalAlignment="Center"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1" SelectedIndex="{Binding CustomCrossoverIndex}"
                                   ItemsSource="{Binding CrossoverList}" Margin="2" HorizontalAlignment="Stretch"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Frequency range rolloff" Margin="4" VerticalAlignment="Center"
                                   ToolTip.Tip="Highest frequency at which MultEQ applies correction. Above this, the speaker's natural response passes through untouched. The chart marks the cutoff with a dotted vertical line and stops the projected target there."/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding FrequencyRangeRolloff}" Margin="2"
                                   LostFocus="OnTargetProjectionInputChanged"
                                   ToolTip.Tip="Highest frequency at which MultEQ applies correction. Default 20000 = full audible band. Lower values restrict correction to the bass/midrange."/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Custom speaker type" Margin="4" VerticalAlignment="Center"/>
                        <ComboBox  Grid.Row="2" Grid.Column="1" SelectedItem="{Binding CustomSpeakerType}"
                                   ItemsSource="{Binding SpeakerTypeList}" Margin="2" HorizontalAlignment="Stretch"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Channel type" Margin="4" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding EnChannelType}" Margin="2" IsReadOnly="True"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Command id" Margin="4" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding CommandId}" Margin="2" IsReadOnly="True"/>
                      </Grid>
                    </ScrollViewer>
                  </TabItem>
                  <TabItem Header="Report" DataContext="{Binding #channelsView.SelectedItem.Channel.ChannelReport}">
                    <ScrollViewer>
                      <Grid Margin="6">
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="160" MinWidth="120"/>
                          <ColumnDefinition Width="*" MinWidth="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Speaker connect" Margin="4" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding EnSpeakerConnect}" Margin="2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Custom speaker connect" Margin="4" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding CustomEnSpeakerConnect}" Margin="2"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Distance (m)" Margin="4" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Distance}" Margin="2"/>
                        <CheckBox  Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                   Content="Reverse polarity" IsChecked="{Binding IsReversePolarity}" Margin="4"/>
                      </Grid>
                    </ScrollViewer>
                  </TabItem>
                </TabControl>
              </Grid>
              <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"/>
              <Grid Grid.Column="2">
                <HeaderedContentControl Header="Graph View">
                  <Grid DataContext="{Binding #channelsView.SelectedItem.Channel}">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="*" MinHeight="220"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0">
                      <TextBlock Text="Measurement position:" VerticalAlignment="Center" Margin="4,0,4,4"/>
                      <ItemsControl x:Name="measurementSlots" Margin="0,0,0,4">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <CheckBox Content="{Binding Label}"
                                      Foreground="{Binding Brush}"
                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                      IsEnabled="{Binding IsEnabled}"
                                      VerticalAlignment="Center"
                                      Margin="3,0,3,0"/>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <CheckBox Content="Select/Unselect all" x:Name="allChbx"
                                IsCheckedChanged="AllCheckBoxMeasurementPositionChanged"
                                VerticalAlignment="Center" Margin="8,0,8,4"/>
                      <CheckBox Content="Show target curve" x:Name="chbxShowTargetCurve"
                                IsChecked="True"
                                IsCheckedChanged="ShowTargetCurve_Changed"
                                VerticalAlignment="Center" Margin="0,0,0,4"
                                ToolTip.Tip="Overlay the selected channel's custom target curve points (and connecting line) on the chart."/>
                    </WrapPanel>
                    <scott:AvaPlot Grid.Row="1" x:Name="plot"/>
                    <WrapPanel Grid.Row="2">
                      <TextBlock Text="Smoothing:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                      <RadioButton GroupName="smoothing" Content="None" Tag="0"  IsCheckedChanged="RadioButtonSmoothingFactorChanged" Margin="0,0,10,4"/>
                      <RadioButton GroupName="smoothing" Content="1/2"  Tag="2"  IsCheckedChanged="RadioButtonSmoothingFactorChanged" Margin="0,0,10,4"/>
                      <RadioButton GroupName="smoothing" Content="1/3"  Tag="3"  IsCheckedChanged="RadioButtonSmoothingFactorChanged" Margin="0,0,10,4"/>
                      <RadioButton GroupName="smoothing" Content="1/6"  Tag="6"  IsCheckedChanged="RadioButtonSmoothingFactorChanged" Margin="0,0,10,4"/>
                      <RadioButton GroupName="smoothing" Content="1/12" Tag="12" IsCheckedChanged="RadioButtonSmoothingFactorChanged" Margin="0,0,10,4" IsChecked="True"/>
                      <RadioButton GroupName="smoothing" Content="1/24" Tag="24" IsCheckedChanged="RadioButtonSmoothingFactorChanged" Margin="0,0,10,4"/>
                      <RadioButton GroupName="smoothing" Content="1/48" Tag="48" IsCheckedChanged="RadioButtonSmoothingFactorChanged" Margin="0,0,10,4"/>
                    </WrapPanel>
                    <WrapPanel Grid.Row="3">
                      <TextBlock Text="View:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                      <RadioButton GroupName="xrange" Tag="Full"      x:Name="rbXRangeFull"      Content="Frequency response — full (20 Hz – 20 kHz)"
                                   IsCheckedChanged="XRangeChanged" Margin="0,0,10,4" IsChecked="True"
                                   ToolTip.Tip="Magnitude vs. frequency, full audible range. Best for full-range speakers."/>
                      <RadioButton GroupName="xrange" Tag="Subwoofer" x:Name="rbXRangeSubwoofer" Content="Frequency response — sub (10 – 1000 Hz)"
                                   IsCheckedChanged="XRangeChanged" Margin="0,0,10,4"
                                   ToolTip.Tip="Magnitude vs. frequency, low-frequency window. Auto-selected for subwoofer channels."/>
                      <RadioButton GroupName="xrange" Tag="Chirp"     x:Name="rbXRangeChirp"     Content="Impulse response (0 – 350 ms)"
                                   IsCheckedChanged="XRangeChanged" Margin="0,0,10,4"
                                   ToolTip.Tip="Time-domain impulse response — amplitude vs. time in milliseconds. Useful for spotting reflections and arrival timing, not magnitude."/>
                      <CheckBox Content="Logarithmic axis" x:Name="chbxLogarithmicAxis" IsChecked="True"
                                IsCheckedChanged="chbxLogarithmicAxis_Changed" Margin="0,0,0,4"
                                ToolTip.Tip="Use a log frequency axis. Ignored in impulse-response view."/>
                    </WrapPanel>
                  </Grid>
                </HeaderedContentControl>
              </Grid>
            </Grid>
          </Grid>
        </Grid>
      </TabItem>
    </TabControl>

    <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" ResizeDirection="Rows"/>

    <!-- Status strip: receiver hardware quirks summary (AudysseyOne-derived) -->
    <Border Grid.Row="4"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="8,4">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Text="{Binding $parent[Window].DataContext.HardwareInfo}"
                   TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center"
                   Opacity="0.85"/>
        <TextBlock Grid.Column="1"
                   Text="Ratbuddyssey"
                   FontSize="11"
                   Opacity="0.6"
                   VerticalAlignment="Center"/>
      </Grid>
    </Border>
  </Grid>
</Window>
